---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    </head>
    <body>
        <Header />
        <main>
            <div class="comic-grid">
                <div class="panel hero-panel">
                    <h1>FULLSTACK<br />DEVELOPER</h1>
                    <div class="action-lines"></div>
                </div>

                <div class="panel profile-panel">
                    <img
                        src="/avatar/programerMalas.webp"
                        alt="Profile Picture"
                    />
                    <div class="caption-box">Programer Malas</div>
                </div>

                <div class="panel intro-panel">
                    <div class="speech-bubble">
                        <p>
                            <strong>Yo!</strong> I'm the developer you're looking
                            for.
                        </p>
                        <p>
                            I build <em>blazing fast</em> websites and robust applications.
                        </p>
                    </div>
                </div>

                <div class="panel social-panel">
                    <div class="social-label">Find Me On</div>
                    <div class="social-badges">
                        <a
                            href="https://github.com/aliemtakarai"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="social-badge github"
                            aria-label="GitHub"
                        >
                            <svg
                                class="badge-icon"
                                viewBox="0 0 24 24"
                                fill="currentColor"
                                xmlns="http://www.w3.org/2000/svg"
                            >
                                <path
                                    d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"
                                ></path>
                            </svg>
                            <span>GitHub</span>
                        </a>

                        <a
                            href="https://www.linkedin.com/in/aliem-arif-perkasa/"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="social-badge linkedin"
                            aria-label="LinkedIn"
                        >
                            <svg
                                class="badge-icon"
                                viewBox="0 0 24 24"
                                fill="currentColor"
                                xmlns="http://www.w3.org/2000/svg"
                            >
                                <path
                                    d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                                ></path>
                            </svg>
                            <span>LinkedIn</span>
                        </a>
                    </div>
                </div>

                <div class="panel content-panel">
                    <h2>Latest Transmission</h2>
                    <p>
                        Welcome to my digital HQ. This site is built with
                        <a href="https://astro.build/">Astro</a>. It's
                        lightweight, fast, and now...
                    </p>
                    <div class="cta-container">
                        <a href="/blog" class="btn">Read Blog</a>
                    </div>
                </div>
            </div>
        </main>
        <Footer />
    </body>
</html>

<style>
    .comic-grid {
        display: grid;
        grid-template-columns: 2fr 1fr;
        grid-template-rows: auto auto auto;
        gap: 1.5rem;
    }

    .panel {
        border: 3px solid var(--black);
        padding: 1.5rem;
        background: var(--white);
        box-shadow: 5px 5px 0 var(--black);
        position: relative;
        overflow: hidden;
        transition: transform 0.2s;
    }

    .panel:hover {
        transform: translate(-2px, -2px);
        box-shadow: 7px 7px 0 var(--black);
    }

    .hero-panel {
        grid-column: 1 / 2;
        grid-row: 1 / 2;
        background-color: var(--accent);
        color: var(--white);
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 300px;
        transform: rotate(-1deg);
        z-index: 2;
    }

    .profile-panel {
        grid-column: 2 / 3;
        grid-row: 1 / 2;
        padding: 0;
        display: flex;
        flex-direction: column;
    }

    .profile-panel img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border: none;
        box-shadow: none;
    }

    .caption-box {
        background: var(--black);
        color: var(--white);
        font-family: "Bangers", cursive;
        text-align: center;
        padding: 0.5rem;
        font-size: 1.2rem;
        letter-spacing: 1px;
    }

    .hero-panel h1 {
        color: var(--white);
        text-shadow: 4px 4px 0 var(--black);
        font-size: 3.5rem;
        text-align: center;
        line-height: 0.9;
        z-index: 2;
        -webkit-text-stroke: 2px var(--black);
    }

    .action-lines {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: repeating-linear-gradient(
            45deg,
            transparent,
            transparent 10px,
            rgba(0, 0, 0, 0.1) 10px,
            rgba(0, 0, 0, 0.1) 20px
        );
        z-index: 1;
    }

    .intro-panel {
        grid-column: 1 / -1;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: var(--gray-light);
        min-height: 150px;
    }

    .speech-bubble {
        background: var(--white);
        border: 3px solid var(--black);
        padding: 1.5rem;
        border-radius: 50% 50% 50% 50% / 40% 40% 60% 60%;
        position: relative;
        max-width: 400px;
        text-align: center;
        box-shadow: 3px 3px 0 rgba(0, 0, 0, 0.1);
    }

    .speech-bubble::after {
        content: "";
        position: absolute;
        top: -20px;
        right: 20%;
        width: 0;
        height: 0;
        border-left: 20px solid transparent;
        border-right: 0px solid transparent;
        border-bottom: 20px solid var(--black);
    }
    .speech-bubble::before {
        content: "";
        position: absolute;
        top: -13px;
        right: 21%;
        width: 0;
        height: 0;
        border-left: 16px solid transparent;
        border-right: 0px solid transparent;
        border-bottom: 16px solid var(--white);
        z-index: 1;
    }

    .content-panel {
        grid-column: 1 / -1;
    }

    .highlight {
        background: linear-gradient(
            120deg,
            var(--accent) 0%,
            var(--accent) 100%
        );
        background-repeat: no-repeat;
        background-size: 100% 0.3em;
        background-position: 0 88%;
        font-weight: bold;
    }

    .cta-container {
        margin-top: 1.5rem;
        display: flex;
        gap: 1rem;
    }

    .btn.secondary {
        background: var(--black);
        color: var(--white);
    }

    .graphics-panel {
        background: var(--black);
        color: var(--white);
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
    }

    .graphics-panel h3 {
        color: var(--white);
        border: 2px solid var(--white);
        padding: 0.5rem;
        transform: rotate(3deg);
    }

    /* ── Social badges panel ── */
    .social-panel {
        grid-column: 1 / -1;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
        background: var(--gray-light);
        padding: 1.5rem;
    }

    .social-label {
        font-family: "Bangers", cursive;
        font-size: 1.4rem;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: var(--black);
        border: 3px solid var(--black);
        background: var(--accent);
        color: var(--white);
        padding: 2px 14px;
        box-shadow: 3px 3px 0 var(--black);
        transform: rotate(-1deg);
    }

    .social-badges {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        justify-content: center;
    }

    .social-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1.1rem;
        border: 3px solid var(--black);
        box-shadow: 4px 4px 0 var(--black);
        font-family: "Bangers", cursive;
        font-size: 1.1rem;
        letter-spacing: 1px;
        text-transform: uppercase;
        text-decoration: none;
        transition:
            transform 0.15s,
            box-shadow 0.15s;
        border-radius: 0;
        /* override global a:hover */
        background: var(--white);
        color: var(--black);
        border-bottom: 3px solid var(--black);
        margin: 0;
    }

    .social-badge:hover {
        transform: translate(-3px, -3px);
        box-shadow: 7px 7px 0 var(--black);
        /* reset global overrides */
        background: var(--white);
        color: var(--black);
        padding: 0.5rem 1.1rem;
        margin: 0;
        border: 3px solid var(--black);
    }

    .social-badge:active {
        transform: translate(2px, 2px);
        box-shadow: 2px 2px 0 var(--black);
    }

    /* Per-platform accent colours */
    .social-badge.github {
        background: #24292e;
        color: #fff;
    }
    .social-badge.github:hover {
        background: #24292e;
        color: #fff;
    }

    .social-badge.linkedin {
        background: #0077b5;
        color: #fff;
    }
    .social-badge.linkedin:hover {
        background: #0077b5;
        color: #fff;
    }

    .social-badge.twitter {
        background: #000;
        color: #fff;
    }
    .social-badge.twitter:hover {
        background: #000;
        color: #fff;
    }

    .social-badge.instagram {
        background: linear-gradient(
            135deg,
            #f09433,
            #e6683c,
            #dc2743,
            #cc2366,
            #bc1888
        );
        color: #fff;
    }
    .social-badge.instagram:hover {
        background: linear-gradient(
            135deg,
            #f09433,
            #e6683c,
            #dc2743,
            #cc2366,
            #bc1888
        );
        color: #fff;
    }

    .badge-icon {
        width: 20px;
        height: 20px;
        flex-shrink: 0;
        border: none;
        box-shadow: none;
        display: block;
    }

    @media (max-width: 768px) {
        .comic-grid {
            grid-template-columns: 1fr;
            grid-template-rows: auto;
        }

        .hero-panel,
        .profile-panel,
        .intro-panel {
            grid-column: auto;
            grid-row: auto;
        }

        .hero-panel {
            transform: rotate(0deg);
        }

        .speech-bubble {
            max-width: 100%;
            border-radius: 12px;
        }
        .speech-bubble::after,
        .speech-bubble::before {
            display: none;
        }
    }
</style>
